<% if invoices.any? %>
  <div class="app-table-wrap app-invoice-table-wrap">
    <table class="app-data-table app-invoice-table" aria-label="Invoices">
      <thead>
        <tr>
          <th scope="col">Customer</th>
          <th scope="col">Invoice</th>
          <th scope="col"><%= amount_label %></th>
          <th scope="col">Timing</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <% invoices.each do |invoice| %>
          <% invoice_status = status ? { label: status, tone: tone } : receivable_invoice_status(invoice, as_of: @dashboard.as_of) %>
          <% timing_label = if invoice_status.fetch(:label) == "Paid"
            invoice.paid_on ? "Paid #{I18n.l(invoice.paid_on, format: "%b %-d")}" : "Payment recorded"
          elsif invoice.due_on.blank?
            "No due date"
          elsif invoice.due_on < @dashboard.as_of
            "#{pluralize((@dashboard.as_of - invoice.due_on).to_i, "day")} overdue"
          elsif invoice.due_on == @dashboard.as_of
            "Due today"
          else
            "Due in #{pluralize((invoice.due_on - @dashboard.as_of).to_i, "day")}"
          end %>
          <tr class="app-invoice-row">
            <td data-label="Customer">
              <div class="app-invoice-row__customer">
                <%= link_to invoice.contact_name.presence || "Unknown customer",
                      customer_path(Customers::Profile.to_param_for(invoice)),
                      class: "app-data-link" %>
              </div>
            </td>
            <td class="app-data-table__muted" data-label="Invoice">
              <div class="app-invoice-row__reference">
                <strong><%= invoice.number.presence || invoice.external_id %></strong>
                <span class="app-provider-badge app-provider-badge--<%= invoice.invoice_source.provider %>">
                  <%= invoice.invoice_source.provider.titleize %>
                </span>
              </div>
            </td>
            <td data-label="<%= amount_label %>">
              <strong class="app-invoice-row__amount"><%= receivable_amount(invoice.public_send(amount_method), invoice.currency) %></strong>
            </td>
            <td class="app-data-table__muted" data-label="Timing">
              <div class="app-invoice-row__timing">
                <strong><%= timing_label %></strong>
                <% if invoice.due_on %>
                  <span>Due <%= I18n.l(invoice.due_on, format: "%b %-d, %Y") %></span>
                <% end %>
              </div>
            </td>
            <td data-label="Status">
              <span class="app-pill app-pill--<%= invoice_status.fetch(:tone) %>"><%= invoice_status.fetch(:label) %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="app-empty-inline"><%= empty_message %></div>
<% end %>

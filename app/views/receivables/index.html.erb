<% @page_title = "Receivables" %>
<% @body_class = "app-workspace" %>

<%= render "receivables/nav", active: :home %>

<%
  aging_buckets = [
    { label: "Current", value: "$8,400" },
    { label: "30-60 days", value: "$2,900" },
    { label: "60-90 days", value: "$950" },
    { label: "90+ days", value: "$250" }
  ]

  invoice_rows = [
    { customer: "Acme Corp.", amount: "$122,300", due: "Oct 15", status: "Overdue", tone: "red" },
    { customer: "Tech Solutions", amount: "$10,000", due: "Oct 28", status: "Reminded", tone: "orange" },
    { customer: "Global Inc.", amount: "$16,000", due: "Nov 02", status: "Awaiting reply", tone: "slate" },
    { customer: "Vertex Ltd.", amount: "$12,000", due: "Nov 13", status: "Escalated", tone: "amber" },
    { customer: "Spark Industries", amount: "$20,000", due: "Oct 22", status: "Reminded", tone: "orange" }
  ]
%>

<h1 class="app-page-title">Accounts Receivable Dashboard</h1>

<div class="app-stat-grid">
  <article class="app-card app-stat-card">
    <div class="app-card__headline">
      <span>Outstanding Invoices</span>
      <span class="app-pill app-pill--green">on track</span>
    </div>
    <div class="app-metric-value">$122,300</div>
  </article>

  <article class="app-card app-stat-card">
    <h2 class="app-card__title">Aging Buckets</h2>
    <div class="app-breakdown-grid">
      <% aging_buckets.each do |bucket| %>
        <div>
          <div class="app-breakdown-grid__label"><%= bucket[:label] %></div>
          <div class="app-breakdown-grid__value"><%= bucket[:value] %></div>
        </div>
      <% end %>
    </div>
  </article>
</div>

<div class="app-card app-table-card">
  <div class="app-table-wrap">
    <table class="app-data-table">
      <thead>
        <tr>
          <th scope="col">Customer</th>
          <th scope="col">Amount Overdue</th>
          <th scope="col">Due Date</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <% invoice_rows.each do |invoice| %>
          <tr>
            <td><%= invoice[:customer] %></td>
            <td><%= invoice[:amount] %></td>
            <td class="app-data-table__muted"><%= invoice[:due] %></td>
            <td>
              <span class="app-pill app-pill--<%= invoice[:tone] %>"><%= invoice[:status] %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

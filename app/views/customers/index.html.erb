<% @page_title = "Customers" %>
<% @body_class = "app-workspace" %>

<%= render "receivables/nav", active: :customers %>

<header class="app-page-header">
  <div>
    <h1 class="app-page-title">Customers</h1>
    <p class="app-page-subtitle">Review collection status, customer conversations, and the next move for every account.</p>
  </div>
</header>

<% if @customers.any? %>
  <section class="app-invoice-section app-customer-portfolio" aria-labelledby="customer-portfolio-title">
    <header class="app-section-header">
      <div>
        <h2 id="customer-portfolio-title">Customer inbox</h2>
        <p>Latest conversation context alongside each account's collection position.</p>
      </div>
      <span aria-label="<%= pluralize(@customers.size, "customer") %>"><%= @customers.size %></span>
    </header>

    <div class="app-card app-table-card">
      <div class="app-table-wrap">
        <table class="app-data-table app-customer-table">
          <thead>
            <tr>
              <th scope="col">Customer</th>
              <th scope="col">Collection status and balance</th>
              <th scope="col">Conversation</th>
              <th scope="col">Next move</th>
            </tr>
          </thead>
          <tbody class="app-customer-list">
            <% @customers.each do |customer| %>
              <% preview = communication_preview_for(customer) %>
              <% segment = collection_segment_for(customer) %>
              <tr class="app-customer-card" data-customer-status="<%= customer.attention_segment.parameterize %>" data-conversation-state="<%= preview.fetch(:state) %>" data-collection-segment="<%= segment.fetch(:key) %>">
                <td class="app-customer-card__identity" data-label="Customer">
                  <%= link_to customer.name, customer_path(customer), class: "app-data-link" %>
                  <div class="app-customer-card__segment">
                    <span class="app-pill app-pill--<%= segment.fetch(:tone) %>"><%= segment.fetch(:name) %></span>
                  </div>
                </td>
                <td class="app-customer-card__collection" data-label="Collection status and balance">
                  <div class="app-customer-card__collection-heading">
                    <span class="app-pill app-pill--<%= customer_attention_tone(customer) %>"><%= customer.attention_segment %></span>
                    <strong class="app-customer-card__amount"><%= receivable_totals(customer.outstanding_totals) %></strong>
                  </div>
                  <div class="app-table-note app-customer-card__collection-context">
                    <% if customer.oldest_overdue_days %>
                      <%= pluralize(customer.oldest_overdue_days, "day") %> overdue
                    <% elsif customer.outstanding_invoices.any? %>
                      <%= pluralize(customer.outstanding_invoices.size, "open invoice") %>
                    <% else %>
                      No open invoices
                    <% end %>
                  </div>
                </td>
                <td class="app-customer-card__conversation" data-label="Conversation">
                  <div class="app-customer-card__conversation-meta">
                    <span class="app-pill app-pill--<%= preview.fetch(:tone) %>"><%= preview.fetch(:status) %></span>
                    <% if preview.fetch(:timestamp).present? %>
                      <span class="app-customer-card__conversation-time"><%= preview.fetch(:timestamp) %></span>
                    <% end %>
                  </div>
                  <div class="app-customer-card__conversation-copy">
                    <p class="app-table-note"><%= preview.fetch(:snippet) %></p>
                  </div>
                </td>
                <td class="app-customer-card__next-step" data-label="Next move">
                  <strong class="app-customer-card__next-move"><%= preview.fetch(:next_step) %></strong>
                  <%= link_to customer_path(customer), class: "app-customer-card__action", aria: { label: "Review #{customer.name}: #{preview.fetch(:next_step)}" } do %>
                    Review customer
                    <span aria-hidden="true">&rarr;</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
<% else %>
  <section class="app-empty-state">
    <h2>No customer profiles yet</h2>
    <p>Customer profiles appear after issued invoices have synced.</p>
  </section>
<% end %>

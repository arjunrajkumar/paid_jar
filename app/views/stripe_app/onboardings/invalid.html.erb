<% @page_title = "Stripe connection expired" %>

<div class="auth-shell">
  <div class="auth-panel">
    <div class="auth-logo" aria-hidden="true">
      <%= render "layouts/shared/logo_mark", suffix: "stripe-onboarding-expired", width: 48, height: 56 %>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">Start again from Stripe</h1>
      <p class="auth-subtitle">
        This secure connection link expired or was already used. Open PaymentReminder in Stripe and start setup again.
      </p>
    </div>
  </div>
</div>

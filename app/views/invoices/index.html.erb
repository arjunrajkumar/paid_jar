<h1>Invoices</h1>

<% if @xero_integration&.connected? %>
  <p>Connected to <%= @xero_integration.external_account_name.presence || "Xero" %>.</p>
<% else %>
  <p><%= link_to "Connect Xero", new_xero_connection_path %></p>
<% end %>

<% if @invoices.any? %>
  <table>
    <thead>
      <tr>
        <th>Number</th>
        <th>Customer</th>
        <th>Status</th>
        <th>Issued</th>
        <th>Due</th>
        <th>Total</th>
        <th>Due amount</th>
      </tr>
    </thead>
    <tbody>
      <% @invoices.each do |invoice| %>
        <tr>
          <td><%= invoice.number.presence || invoice.external_id %></td>
          <td><%= invoice.contact_name %></td>
          <td><%= invoice.status %></td>
          <td><%= invoice.issued_on %></td>
          <td><%= invoice.due_on %></td>
          <td><%= number_to_currency invoice.total, unit: "#{invoice.currency} " %></td>
          <td><%= number_to_currency invoice.amount_due, unit: "#{invoice.currency} " %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No invoices synced yet.</p>
<% end %>

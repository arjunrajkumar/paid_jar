<!DOCTYPE html>
<html lang="en">
  <%= render "layouts/shared/head" %>

  <body class="<%= body_classes %>" data-controller="timezone-cookie" data-platform="<%= platform.type %>">
    <div id="global-container">
      <nav id="nav" class="app-nav" aria-label="Application navigation" data-controller="toggle-class" data-toggle-class-toggle-class="open">
        <%= yield :nav %>
      </nav>

      <main id="main" class="app-main">
        <%= render "layouts/shared/flash" %>
        <%= render "layouts/shared/time_zone" if Current.user %>
        <%= yield :header %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
